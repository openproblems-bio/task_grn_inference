Bootstrap: docker
From: python:3.11-slim

%labels
    Author jalil.nourisa@gmail.com
    Description GeneRNBI Agentic Assistant – Biomni A1 + LlamaIndex RAG

%post
    set -e

    # System dependencies
    apt-get update -qq && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
        ca-certificates \
        libgomp1 \
        && rm -rf /var/lib/apt/lists/*

    # Core scientific stack (mirrors Biomni environment.yml)
    pip install --no-cache-dir \
        "numpy==2.1" \
        pandas \
        matplotlib \
        scipy \
        statsmodels \
        scikit-learn \
        tqdm \
        seaborn \
        networkx \
        requests \
        pyyaml \
        beautifulsoup4 \
        lxml \
        python-dotenv

    # LangChain / LangGraph (Biomni runtime)
    pip install --no-cache-dir \
        langchain \
        "langgraph==0.3.18" \
        langchain-openai \
        langchain-anthropic \
        langchain-ollama \
        langchain-community \
        openai

    # Transformer / NLP utilities (used for local HuggingFace embeddings)
    pip install --no-cache-dir \
        transformers \
        sentencepiece \
        sentence-transformers

    # Biomni agent
    pip install --no-cache-dir \
        mcp \
        tooluniverse \
        biomni

    # LlamaIndex RAG stack (used by rag_builder.py and agent.py)
    pip install --no-cache-dir \
        llama-index-core \
        llama-index-llms-openai \
        llama-index-llms-anthropic \
        llama-index-embeddings-openai \
        llama-index-embeddings-huggingface

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    # Default: run the agentic assistant
    # Usage inside container:
    #   singularity run agentic.sif [optional question]
    cd /agentic/src
    exec python run.py "$@"

%help
    GeneRNBI Agentic Assistant container.

    Quick start:
        singularity run --bind /path/to/task_grn_inference:/agentic \
            agentic.sif

    Single-query mode:
        singularity run --bind /path/to/task_grn_inference:/agentic \
            agentic.sif "How do I add a new GRN method?"

    Required environment variables (set before running):
        export OPENAI_API_KEY=sk-...       # if using OpenAI (default)
        export ANTHROPIC_API_KEY=sk-ant-... # if using Anthropic
